{
  "identifier": "default",
  "description": "Default capabilities for the Polter main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
